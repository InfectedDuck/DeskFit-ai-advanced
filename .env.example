# LLM Configuration
# The system uses an OpenAI-compatible API. Works with EPAM DIAL, Groq, OpenAI, etc.

# Option 1: EPAM DIAL
# DIAL_API_BASE=https://dial.epam.com/openai/deployments/gpt-4o-mini/chat/completions
# DIAL_API_KEY=your-dial-key-here
# DIAL_MODEL_NAME=gpt-4o-mini

# Option 2: Groq (free at console.groq.com)
DIAL_API_BASE=https://api.groq.com/openai/v1
DIAL_API_KEY=your-groq-api-key-here
DIAL_MODEL_NAME=llama-3.3-70b-versatile
